# ============================================================
#  ProdEx — Environment Variables
#  Copy this file to .env and fill in your values
# ============================================================

# ── LOCAL mode (Ollama) ────────────────────────────────────
# Requires Ollama running locally: ollama serve
# Pull model first: ollama pull mistral:7b-instruct
OLLAMA_MODEL=mistral:7b-instruct
OLLAMA_BASE_URL=http://localhost:11434

# ── CLOUD mode (Groq) — overrides Ollama when set ─────────
# Free API key at: console.groq.com
# When GROQ_API_KEY is set, Ollama is NOT used
GROQ_API_KEY=
GROQ_MODEL=llama3-8b-8192

# ── Hugging Face Hub (cloud FAISS index) ───────────────────
# Set this so the app auto-downloads the index on cloud startup
# Format: your-username/prodex-index
HF_REPO_ID=

# ── Download settings ──────────────────────────────────────
MAX_PRODUCTS=0

# ── Search settings ────────────────────────────────────────
TOP_K=5
