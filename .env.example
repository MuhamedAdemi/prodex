# ============================================================
#  ProdEx — Environment Variables
#  Copy this file to .env and fill in your values
# ============================================================

# ── Local LLM (Ollama) ─────────────────────────────────────
# Make sure Ollama is running: ollama serve
# Pull the model first: ollama pull mistral:7b-instruct
OLLAMA_MODEL=mistral:7b-instruct
OLLAMA_BASE_URL=http://localhost:11434

# ── Download settings ──────────────────────────────────────
# How many products to download (200 = fast test, 0 = all 42k)
MAX_PRODUCTS=0

# ── Search settings ────────────────────────────────────────
# Number of products to retrieve per query
TOP_K=5
